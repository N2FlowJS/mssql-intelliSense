<Window x:Class="MssqlIntelliSense.SsmsHost.MssqlIntelliSenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MssqlIntelliSense.SsmsHost"
        mc:Ignorable="d"
        Title="MSSQL IntelliSense - Schema Explorer" Height="750" Width="1000"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
        Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}">

    <Window.Resources>
        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.SystemButtonFaceBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.SystemButtonTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.CommandBarMouseOverBackgroundGradientBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.SystemHighlightBrushKey}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.SystemHighlightTextBrushKey}}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- HierarchicalDataTemplate for TreeViewItemViewModel -->
        <HierarchicalDataTemplate DataType="{x:Type local:TreeViewItemViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Height="20">
                <Image Source="{Binding IconSource}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            </StackPanel>
        </HierarchicalDataTemplate>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" />
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}" />
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="TreeViewItem_PreviewMouseRightButtonDown" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBorderBrushKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBackgroundBrushKey}}" />
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}" />
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBorderBrushKey}}" />
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}" />
        </Style>

        <Style x:Key="SidebarNavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="200" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar: Connections TreeView -->
        <Grid Grid.Column="0" Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Sidebar Header -->
            <Border Grid.Row="0" Padding="15" BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="SQLITE CACHE" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
                    <TextBlock Text="Các database connections đã quét schema" FontSize="11" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Connections TreeView -->
            <TreeView x:Name="ConnectionsTree" Grid.Row="1"
                      ItemsSource="{Binding RootNodes}"
                      SelectedItemChanged="ConnectionsTree_SelectedItemChanged"
                      ContextMenuOpening="ConnectionsTree_ContextMenuOpening">
                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="CopyMenuItem" Header="Sao chép" Click="CopyMenuItem_Click" />
                        <MenuItem x:Name="RefreshMenuItem" Header="Làm mới" Click="RefreshMenuItem_Click" />
                        <Separator />
                        <MenuItem x:Name="ScanSchemaMenuItem" Header="Scan schema" Click="ScanSchemaMenuItem_Click" />
                        <Separator />
                        <MenuItem x:Name="DeleteConnectionMenuItem" Header="Xóa connection" Click="DeleteConnectionMenuItem_Click" />
                    </ContextMenu>
                </TreeView.ContextMenu>
            </TreeView>

            <!-- Sidebar Tools -->
            <Border Grid.Row="2" Padding="10" BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" BorderThickness="0,1,0,0" Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="SettingsNavButton" Grid.Column="0" Style="{StaticResource SidebarNavButton}" Click="SettingsNavButton_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Image x:Name="SettingsNavIcon" Width="16" Height="16" Margin="0,0,6,0" />
                            <TextBlock Text="Settings" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="AboutNavButton" Grid.Column="1" Style="{StaticResource SidebarNavButton}" Margin="6,0,0,0" Click="AboutNavButton_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Image x:Name="AboutNavIcon" Width="16" Height="16" Margin="0,0,6,0" />
                            <TextBlock Text="About" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Grid Splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" ResizeBehavior="PreviousAndNext" />

        <!-- Detail Panel -->
        <Grid Grid.Column="2" Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}">
            
            <!-- Empty State -->
            <Grid Name="EmptyStatePanel" Visibility="Visible" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🗄️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10" />
                    <TextBlock Text="Chưa chọn kết nối nào" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" HorizontalAlignment="Center" />
                    <TextBlock Text="Chọn một database connection ở thanh bên để xem dữ liệu cache chi tiết." FontSize="12" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" Margin="0,5,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Scan Progress Panel -->
            <Grid Name="ScanProgressPanel" Visibility="Collapsed" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock x:Name="ScanProgressTitleText" Text="🔍 ĐANG CẬP NHẬT CACHE SCHEMA" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.SystemHighlightBrushKey}}" />
                    <TextBlock x:Name="ScanProgressStatusText" Text="Đang khởi tạo tiến trình quét..." FontSize="11" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" Margin="0,4,0,0" />
                </StackPanel>

                <TextBox x:Name="ScanLogTextBox" Grid.Row="1" 
                         Background="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBackgroundBrushKey}}" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}" BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBorderBrushKey}}"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         IsReadOnly="True" FontFamily="Consolas, Courier New, monospace" FontSize="12" Padding="10" />
            </Grid>

            <!-- Detail Content Panel -->
            <Grid Name="DetailContentPanel" Visibility="Collapsed">
                <ScrollViewer Name="TabDetailsContent" VerticalScrollBarVisibility="Auto" Margin="18">
                    <StackPanel x:Name="DetailStack">
                        <TextBlock Text="Chọn một đối tượng trong cây để xem chi tiết." FontSize="14" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Settings Panel -->
            <Grid Name="SettingsPanel" Visibility="Collapsed" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="⚙️ HỆ THỐNG &amp; AI SETTINGS" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.SystemHighlightBrushKey}}" />
                    <TextBlock Text="Cấu hình nhà cung cấp LLM và các thiết lập tự động hóa của tiện ích." FontSize="11" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" Margin="0,4,0,0" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        
                        <!-- LLM Group -->
                        <Border BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15" Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowCodeBlockBackgroundBrushKey}}">
                            <StackPanel>
                                <TextBlock Text="CẤU HÌNH AI (LLM PROVIDER)" FontWeight="Bold" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" FontSize="13" Margin="0,0,0,15" />
                                
                                <TextBlock Text="API Endpoint URL:" FontSize="11" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" Margin="0,0,0,4" />
                                <TextBox x:Name="SettingsEndpointTextBox" Padding="6,4" Margin="0,0,0,10" />

                                <TextBlock Text="LLM Model:" FontSize="11" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" Margin="0,0,0,4" />
                                <TextBox x:Name="SettingsModelTextBox" Padding="6,4" Margin="0,0,0,10" />

                                <TextBlock Text="API Key:" FontSize="11" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" Margin="0,0,0,4" />
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <PasswordBox x:Name="SettingsApiKeyPasswordBox" Padding="6,4" Grid.Column="0" />
                                    <TextBox x:Name="SettingsApiKeyTextBox" Padding="6,4" Grid.Column="0" Visibility="Collapsed" />
                                    <Button x:Name="TogglePasswordButton" Content="Hiện" Grid.Column="1" Click="TogglePasswordButton_Click" Width="50" Margin="5,0,0,0" Padding="5,2" FontSize="11" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- MRU Stats -->
                        <Border BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15" Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowCodeBlockBackgroundBrushKey}}">
                            <StackPanel>
                                <TextBlock Text="MRU (MOST RECENTLY USED) CACHE" FontWeight="Bold" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" FontSize="13" Margin="0,0,0,12" />
                                <TextBlock x:Name="SettingsMruStatsText" Text="Loading..." FontSize="11" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Snippet Directory -->
                        <Border BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15" Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowCodeBlockBackgroundBrushKey}}">
                            <StackPanel>
                                <TextBlock Text="SNIPPET DIRECTORY" FontWeight="Bold" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" FontSize="13" Margin="0,0,0,12" />
                                <TextBlock Text="Đường dẫn thư mục chứa tệp snippet .json (để trống dùng snippet mặc định):" FontSize="11" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" Margin="0,0,0,6" TextWrapping="Wrap" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SettingsSnippetDirTextBox" Grid.Column="0" Padding="6,4" />
                                    <Button Grid.Column="1" Content="Browse" Click="SettingsBrowseSnippets_Click" Margin="8,0,0,0" Padding="8,4" FontSize="11" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Khôi phục mặc định" Click="SettingsReset_Click" Padding="12,6" Margin="0,0,10,0" />
                            <Button Content="Lưu cấu hình" Click="SettingsSave_Click" Padding="15,6" Background="{DynamicResource {x:Static vsui:EnvironmentColors.SystemHighlightBrushKey}}" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.SystemHighlightTextBrushKey}}" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- About Panel -->
            <Grid Name="AboutPanel" Visibility="Collapsed" Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="ℹ️ GIỚI THIỆU MSSQL IntelliSense" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.SystemHighlightBrushKey}}" />
                    <TextBlock Text="Thông tin về công cụ phát triển và trạng thái hệ thống." FontSize="11" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" Margin="0,4,0,0" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="3*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Description and Links -->
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="MSSQL IntelliSense" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
                        <TextBlock x:Name="AboutVersionText" Text="Phiên bản: v0.2.71" FontSize="12" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.SystemHighlightBrushKey}}" Margin="0,5,0,10" />
                        
                        <TextBlock Text="Một tiện ích mở rộng gọn nhẹ hỗ trợ gợi ý mã SQL (Autocomplete) thông minh và tối ưu hóa câu lệnh trực tiếp trong SQL Server Management Studio (SSMS)." 
                                   Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" FontSize="13" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,15" />

                        <TextBlock Text="Được phát triển với mục tiêu nâng cao hiệu suất viết truy vấn T-SQL bằng mô hình AI, thay thế các kiến trúc trung gian cồng kềnh bằng các giải pháp chạy trực tiếp trong tiến trình (in-process)." 
                                   Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" FontSize="11.5" TextWrapping="Wrap" LineHeight="16" Margin="0,0,0,0" />
                    </StackPanel>

                    <!-- Right: Technical Details & Stats -->
                    <Border Grid.Column="1" BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowCodeBlockBackgroundBrushKey}}" Padding="20" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="THÔNG TIN HỆ THỐNG" FontWeight="Bold" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" FontSize="13" Margin="0,0,0,15" />

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Đường dẫn Database:" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" FontSize="11" />
                                <TextBlock Grid.Column="1" x:Name="AboutDbPathText" Text="C:\Users\...\MssqlIntelliSense.db" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" FontSize="11" TextWrapping="Wrap" />
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Kích thước Database:" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" FontSize="11" />
                                <TextBlock Grid.Column="1" x:Name="AboutDbSizeText" Text="0 KB" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" FontSize="11" />
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Số lượng kết nối:" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" FontSize="11" />
                                <TextBlock Grid.Column="1" x:Name="AboutConnectionsCountText" Text="0" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" FontSize="11" />
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Môi trường chạy:" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" FontSize="11" />
                                <TextBlock Grid.Column="1" Text=".NET Framework 4.7.2 (in SSMS)" Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" FontSize="11" />
                            </Grid>

                            <Border BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                                <TextBlock Text="Bảo mật: Dữ liệu cấu trúc chỉ được lưu trữ cục bộ trong tệp SQLite trên máy tính của bạn và chỉ các đoạn prompt chỉ định mới được gửi đến nhà cung cấp AI do bạn cấu hình." 
                                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" FontSize="10.5" TextWrapping="Wrap" LineHeight="15" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
