<UserControl x:Class="MssqlIntelliSense.SsmsHost.ToolLabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="760"
             Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
             Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Button x:Name="RefreshConnectionsButton"
                    DockPanel.Dock="Right"
                    Content="Refresh"
                    Click="RefreshConnectionsButton_Click"
                    Padding="10,4"
                    Margin="8,0,0,0" />
            <StackPanel>
                <TextBlock Text="Tool Lab"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" />
                <TextBlock Text="Run schema tools directly against a cached connection."
                           FontSize="11"
                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}"
                           Margin="0,2,0,0" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Connection"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" />
            <ComboBox x:Name="ConnectionsComboBox"
                      Grid.Column="1"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      MinHeight="26"
                      Background="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBackgroundBrushKey}}"
                      Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}"
                      BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBorderBrushKey}}" />
        </Grid>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowBorderBrushKey}}"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,10"
                Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowCodeBlockBackgroundBrushKey}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Action"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" />
                <ComboBox x:Name="ActionComboBox"
                          Grid.Row="0"
                          Grid.Column="1"
                          Margin="0,0,8,8"
                          SelectedIndex="0"
                          MinHeight="26">
                    <ComboBoxItem Content="list_tables" Tag="list_tables" />
                    <ComboBoxItem Content="get_table_schema" Tag="get_table_schema" />
                    <ComboBoxItem Content="get_table_relations" Tag="get_table_relations" />
                    <ComboBoxItem Content="get_table_indexes" Tag="get_table_indexes" />
                    <ComboBoxItem Content="search_objects" Tag="search_objects" />
                    <ComboBoxItem Content="find_column" Tag="find_column" />
                    <ComboBoxItem Content="list_endpoints" Tag="list_endpoints" />
                </ComboBox>
                <Button x:Name="RunToolButton"
                        Grid.Row="0"
                        Grid.Column="2"
                        Content="Run"
                        Click="RunToolButton_Click"
                        Padding="18,4"
                        Margin="0,0,0,8" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="Schema"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" />
                <TextBox x:Name="SchemaTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Grid.ColumnSpan="2"
                         Text="dbo"
                         Padding="6,4"
                         Margin="0,0,0,8"
                         Background="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBackgroundBrushKey}}"
                         Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBorderBrushKey}}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="Table"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" />
                <TextBox x:Name="TableTextBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Grid.ColumnSpan="2"
                         Padding="6,4"
                         Margin="0,0,0,8"
                         Background="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBackgroundBrushKey}}"
                         Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBorderBrushKey}}" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Text="Query"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelTextBrushKey}}" />
                <TextBox x:Name="QueryTextBox"
                         Grid.Row="3"
                         Grid.Column="1"
                         Grid.ColumnSpan="2"
                         Padding="6,4"
                         Background="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBackgroundBrushKey}}"
                         Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBorderBrushKey}}" />
            </Grid>
        </Border>

        <TabControl Grid.Row="3">
            <TabItem Header="Grid">
                <DataGrid x:Name="OutputDataGrid"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          Background="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBackgroundBrushKey}}"
                          Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}" />
            </TabItem>
            <TabItem Header="JSON">
                <TextBox x:Name="OutputTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Courier New, monospace"
                         FontSize="12"
                         Padding="8"
                         Background="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBackgroundBrushKey}}"
                         Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxTextBrushKey}}"
                         BorderBrush="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxBorderBrushKey}}" />
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
